
datasource db {
  provider = "postgresql"
  schemas  = ["app", "auth"]
}

generator client {
  provider = "prisma-client-js"
}

enum Theme {
  DARK
  LIGHT
  @@schema("app")
}

// ModerationStatus est le status que renvoie l'IA apres avoir placé analysé le post //

enum ModerationStatus {
  SAFE
  UNCERTAIN
  UNSAFE

  @@schema("app")
}


enum Category {
  TECH
  BUSINESS
  SOCIETY
  POLITICS
  EDUCATION
  HEALTH
  SPORTS
  ENTERTAINMENT
  CULTURE_ARTS
  @@schema("app")
}

enum NotificationsTypes {
  LIKE
  COMMENT
  FOLLOW
  @@schema("app")
}

enum language {
  FRENCH
  ENGLISH
  SPANISH
  @@schema("app")
}

enum Intent {
  DISCOVER
  PUBLISH
  READ
  DEBATE
  NETWORK
@@schema("app")
}

// isAi est un champs boolean qui vaut true quand le compte ou le post est générée par IA //

model UserProfile {
  id String @id @unique @default(cuid())

  // RELATION AVEC TABLES BETTER AUTH //
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  username String? @unique
  displayname String 
  // URL Car Sauvegarder dans Cloudinary//
  avatarUrl   String?
  avatarPublicId String?
  bannerUrl   String?
  bannerPublicId String?
  bio         String?
  language    String
  theme       Theme    @default(DARK)
  createdAt   DateTime @default(now())
  // SOFT_DELETE //
  deletedAt        DateTime?
  defineltyDeleted DateTime?

  pinnedPostId       String? 
  
  // Champs pour le tracking //
  hasAcceptedCookies Boolean   @default(false)
  last_login_at      DateTime?
  last_seen_at       DateTime?
  utm_source         String?
  utm_medium         String?
  utm_campaign       String?
  referrer_domain    String?
  visitCountBeforeLogin Int?
  anonymeCreatedAt DateTime?


  hasOnboarded Boolean @default(false)
  onboardedStep Int @default(0)
  intent Intent?
  occupation String?

  isAi  Boolean    @default(false)


  // Socially Pro //
  isPro Boolean @default(false)


  
  likes PostLike[]
  post  Post[]
  categories Category[] @default([])

  userCommentLike CommentLike[]

  TriggeredNotifications Notifications[] @relation("TriggeredNotifications")
  ReceiverNotifications  Notifications[] @relation("ReceiverNotifications")

  relationWhereUserIsFollowed  Follow[] @relation("FollowedProfile") // Profils des utilisateurs qui suivent User //
  relationWhereUserIsFollower Follow[] @relation("FollowerProfile") // Profils des utilisateurs suivie par User //



  blocked Block[] @relation("blocked")
  blocker Block[] @relation("Blocker")

  report Report[]

  userMessage         Message[] @relation("Sender")
  userReceivedMessage Message[] @relation("Receiver")

  userComment Comment[]

  createdConversations          Conversation[] @relation("ConversationCreator")
  conversationsAsParticipantOne Conversation[] @relation("ConversationParticipantOne")
  conversationsAsParticipantTwo Conversation[] @relation("ConversationParticipantTwo")

  userParticipationConv ConversationParticipant[]
  SearchHistory         SearchHistory[]

  @@schema("app")
}

model AnonymousVisitor {
  id String @id @unique @default(cuid())

  visitorId          String   @unique @default(cuid())
  hasAcceptedCookies Boolean  @default(false)
  visitCount         Int      @default(1)
  language           String
  createdAt          DateTime @default(now())

  utm_source      String?
  utm_medium      String?
  utm_campaign    String?
  referrer_domain String?

  @@schema("app")
}

model Post {
  id        String    @id @default(cuid())
  title     String
  content   String?
  slug      String @unique  
  imagesUrl    String[]
  imagesPublicId String[]
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  categories Category[] @default([]) @map("Category")

  moderationStatus ModerationStatus
  comment          Comment[]
  likes            PostLike[]
  notif            Notifications[]
  postShared       Message[]
  reported         Report[]
  userId           String
  author           UserProfile      @relation(fields: [userId], references: [id])

  @@schema("app")
}

model Report {
  id        String    @id @default(cuid())
  createdAt DateTime @default(now())

  postId      String
  post        Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  reporterId  String
  reporter    UserProfile         @relation(fields: [reporterId], references: [id])

  @@unique([reporterId, postId])
  @@schema("app")
}

model Comment {
  id               String           @id @default(cuid())
  content          String
  createdAt        DateTime         @default(now())
  deletedAt        DateTime?
  moderationStatus ModerationStatus

  // A quel comment le comment est dédiée //
  responseToCommentId String?
  responseToComment   Comment? @relation("CommentReplies", fields: [responseToCommentId], references: [id])

  replies Comment[] @relation("CommentReplies")

  Likes    CommentLike[]
  authorId String
  author   UserProfile   @relation(fields: [authorId], references: [id])
  postId   String
  post     Post          @relation(fields: [postId], references: [id])

  @@schema("app")
}

// Table Pivot, nécessaire d'en créer une manuellement car besoin de faire des requete dessus //

model PostLike {
  id String @id @default(cuid())

  post_id String
  post    Post   @relation(fields: [post_id], references: [id])

  user_id String
  user    UserProfile @relation(fields: [user_id], references: [id])

  createdAt DateTime @default(now())

  @@unique([user_id, post_id])
  @@schema("app")
}

// Table Pivot, nécessaire d'en créer une manuellement car besoin de faire des requete dessus + a ses propres regles métier//

model CommentLike {
  id String @id @default(cuid())

  comment_id String
  comment    Comment @relation(fields: [comment_id], references: [id])

  user_id String
  user    UserProfile @relation(fields: [user_id], references: [id])

  createdAt DateTime @default(now())

  @@unique([user_id, comment_id])
  @@schema("app")
}

model Follow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())


  followedProfileId String
  followedProfile   UserProfile @relation("FollowedProfile", fields: [followedProfileId], references: [id])

  followerProfileId String
  followerProfile   UserProfile @relation("FollowerProfile", fields: [followerProfileId], references: [id])

  @@unique([followedProfileId, followerProfileId])

  @@schema("app")
}

model Block {
  id          String      @id @default(cuid())
  blockedById String
  blocked     UserProfile @relation("blocked", fields: [blockedById], references: [id])

  blockerId String
  blocker   UserProfile @relation("Blocker", fields: [blockerId], references: [id])

  createdAt DateTime @default(now())

  @@unique([blockerId, blockedById])
  @@schema("app")
}

model Conversation {
  id String @id @default(cuid())

  createdAt DateTime @default(now())

  creatorId String
  creator   UserProfile @relation("ConversationCreator", fields: [creatorId], references: [id])

  participantOneId String
  participantOne   UserProfile @relation("ConversationParticipantOne", fields: [participantOneId], references: [id])

  participantTwoId String
  participantTwo   UserProfile @relation("ConversationParticipantTwo", fields: [participantTwoId], references: [id])

  participant ConversationParticipant[]
  messages    Message[]

  @@unique([participantOneId, participantTwoId])
  @@schema("app")
}

model ConversationParticipant {
  id     String      @id @default(cuid())
  userId String
  user   UserProfile @relation(fields: [userId], references: [id])

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@unique([userId, conversationId])
  @@schema("app")
}

model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  senderId String
  sender   UserProfile @relation("Sender", fields: [senderId], references: [id])

  receiverId String
  receiver   UserProfile @relation("Receiver", fields: [receiverId], references: [id])

  imagesUrl String?
  imagesPublicId String?

  sharedPostId String?
  sharedPost   Post?   @relation(fields: [sharedPostId], references: [id], onDelete: SetNull)

  isRead Boolean?

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@schema("app")
}

model Notifications {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String?
  post   Post?   @relation(fields: [postId], references: [id])

  actorId String
  actor   UserProfile @relation("TriggeredNotifications", fields: [actorId], references: [id], onDelete: Cascade)

  type   NotificationsTypes
  isRead Boolean?

  userId    String
  userNotif UserProfile @relation("ReceiverNotifications", fields: [userId], references: [id])

  @@schema("app")
}

model SearchHistory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  query     String

  userId String
  user   UserProfile @relation(fields: [userId], references: [id])

  @@schema("app")
}


model StaffProfile {
  id String @id @default(cuid())
  displayName String 
  // URL Car Sauvegarder dans Cloudinary//
  avatarUrl   String?
  avatarPublicid String?
  deletedAt        DateTime?
  defineltyDeleted DateTime?

 @@schema("auth")
}

// CHAMPS DE BETTER AUTH //

model User {
  id            String   @id
  name          String
  email         String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile  UserProfile?
  sessions Session[]
  accounts Account[]

  AccountType  String
  trackingData Json?

  @@unique([email])
  @@map("user")
  @@schema("auth")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
  @@schema("auth")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
  @@schema("auth")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
  @@schema("auth")
}
