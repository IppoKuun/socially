datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Theme {
    DARK
    LIGHT
}
enum ModerationStatus {
 SAFE
 UNCERTAIN
 UNSAFE
}

// A FAIRE //
enum Category {
    TECH
    SOCIETY
    CULTURE & ARTS
    
}

model UserProfile {
    id String @id @unique @default(cuid())
    email String @unique
    name String
    displayName String
    avatarUrl? String
    bannerUrl? String
    bio? String
    language String
    theme Theme@default(DARK)
    createdAt DateTime @default(now())
    deletedAt? DateTime 
    pinnedPost? 
    last_login_at? DateTime 
    last_seen_at? DateTime
    utm_source?
    utm_medium?
    utm_campaign?
    utm_content?
    referrer_domain?
    hasOnboarded Boolean @default(false)
    isPro Boolean @default(false)
    
    
    likes? PostLike[]
    post? Post[]
    notification?
    followed? Follow[] @relation("Followed")
    followers? Follow[] @relation("Follower")
    blocked?  
    conversation?
}


model Post {
    id String @id @default(cuid())
    title String
    content? String
    images? String[]
    createdAt DateTime @default(now())
    deletedAt? DateTime 
    Category Category
    moderationStatus ModerationStatus
    
    comment Comment[]
    likes? PostLike[]
    userId String
    author UserProfile @relation( fields: [userId], references: [id])
}

model Comment {
    id String @id @default(cuid())
    content String
    images? String[]
    createdAt DateTime @default(now())
    deletedAt? DateTime
    moderationStatus ModerationStatus

    comment? Comment[]

    userId String
    author UserProfile @relation(fields: [userId], references: [id])
    postId String
    post Post @relation(fields: [postId], references: [id])
}


model PostLike {
    id String @id @default(cuid())

    post_id String
    post Post @relation("post", fields: [post_id], references: [id])

    user_id String
    user UserProfile @relation("user", fields: [user_id], references: [id])

    createdAt DateTime @default(now())
    @@unique([user_id, post_id])
}

model CommentLike {
    id String @id @default(cuid())

    comment_id String
    comment Post @relation(fields: [comment_id], references: [id])

    user_id String
    user UserProfile @relation(fields: [user_id], references: [id])

    createdAt DateTime @default(now())
    @@unique([user_id, comment_id])
}


model Follow {
    id String @id @default(cuid())
    createdAt DateTime default(now())

    followedId String
    followed UserProfile @relation("Followed", fields: [userId], references: [followedId])

    followerId String
    follower UserProfile @relation("Follower", fields : [userId], references: [followerId])
}


