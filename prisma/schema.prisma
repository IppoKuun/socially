datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Theme {
    DARK
    LIGHT
}
enum ModerationStatus {
 SAFE
 UNCERTAIN
 UNSAFE
}

// A FAIRE //
enum Category {
    TECH
    SOCIETY
    CULTURE & ARTS
    
}

model UserProfile {
    id String @id @unique @default(cuid())
    email String @unique
    name String
    displayName String
    avatarUrl? String
    bannerUrl? String
    bio? String
    language String
    theme Theme@default(DARK)
    createdAt DateTime @default(now())
    deletedAt? DateTime 
    pinnedPost? 
    last_login_at? DateTime 
    last_seen_at? DateTime
    utm_source?
    utm_medium?
    utm_campaign?
    utm_content?
    referrer_domain?
    hasOnboarded Boolean @default(false)
    isPro Boolean @default(false)
    
    
    likes? PostLike[]
    post? Post[]
    notification? Notifications
    followed? Follow[] @relation("Followed")
    followers? Follow[] @relation("Follower")
    blocked? Bloc[]
    conversation? Conversation[]
    SearchHistory SearchHistory[]?
}


model Post {
    id String @id @default(cuid())
    title String
    content? String
    images? String[]
    createdAt DateTime @default(now())
    deletedAt? DateTime 
    Category Category
    moderationStatus ModerationStatus
    
    comment Comment[]
    likes? PostLike[]
    userId String
    author UserProfile @relation( fields: [userId], references: [id])
}

model Comment {
    id String @id @default(cuid())
    content String
    images? String[]
    createdAt DateTime @default(now())
    deletedAt? DateTime
    moderationStatus ModerationStatus

    comment? Comment[]

    userId String
    author UserProfile @relation(fields: [userId], references: [id])
    postId String
    post Post @relation(fields: [postId], references: [id])
}


model PostLike {
    id String @id @default(cuid())

    post_id String
    post Post @relation("post", fields: [post_id], references: [id])

    user_id String
    user UserProfile @relation("user", fields: [user_id], references: [id])

    createdAt DateTime @default(now())
    @@unique([user_id, post_id])
}

model CommentLike {
    id String @id @default(cuid())

    comment_id String
    comment Post @relation(fields: [comment_id], references: [id])

    user_id String
    user UserProfile @relation(fields: [user_id], references: [id])

    createdAt DateTime @default(now())
    @@unique([user_id, comment_id])
}


model Follow {
    id String @id @default(cuid())
    createdAt DateTime default(now())

    followedId String
    followed UserProfile @relation("Followed", fields: [userId], references: [followedId])

    followerId String
    follower UserProfile @relation("Follower", fields : [userId], references: [followerId])

    @@unique([followedId, followerId])
}

model Block {
    id String @id @default(cuid())
    blockedById String
    blocked UserProfile @relation("blocked", fields: [blockedById], references:[id])

    blockerId String
    blocker UserProfile @relation("Blocker", fields: [blockById], references: [id])

    createdAt DateTime default(now())
    @@unique([blockById, blockerId])

}


model Conversation {
    id String @id @default(cuid())

    createdAt DateTime @default(now())

    messages Message[]
}

model Message {
    id String @default(cuid())
    senderId
    sender UserProfile @relation("Sender", fields: [senderId], references: [id])

    receiverId
    receiver UserProfile @relation("Receiver",fields : [receiverId], references:[id])

    imagesUrl String?

    sharedPostId   String?     
    sharedPost     Post?        @relation(fields: [sharedPostId], references: [id], onDelete: SetNull)

    isRead? DateTime
    conversationId String
    conversation Conversation @relation(fields: [conversationId], references: [id])
}


model Notifications {
    id String @id @default(cuid())

    postId String
    post Post @relation(fields: [postId], references: [id])

    type NotificationsTypes
    isRead Boolean?

    userId String
    userNotif UserProfile(fields: [userId], references: [id])
}

model SearchHistory {
    id String @id @default(cuid())

    postId String
    post Post[] @relation(fields:[postId], references: [id])
}

enum NotificationsTypes {
    LIKE, COMMENT, FOLLOW
}
// A FAIRE => BLOCK/conversation/Message/notif/RechercheHistorique