datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Theme {
    DARK
    LIGHT
}
enum ModeationStatus {
 SAFE
 UNCERTAIN
 UNSAFE
}

// A FAIRE //
enum Category {
    TECH
    SOCIETY
    CULTURE & ARTS
    
}

model UserProfile {
    id String @id @unique @default(cuid())
    email String @unique
    name String
    displayName String
    avatarUrl? String
    bannerUrl? String
    bio? String
    language String
    theme Theme@default(DARK)
    createdAt DateTime @default(now())
    deletedAt? DateTime 
    pinnedPost? 
    last_login_at? DateTime 
    last_seen_at? DateTime
    utm_source?
    utm_medium?
    utm_campaign?
    utm_content?
    referrer_domain?
    hasOnboarded Boolean @default(false)
    isPro Boolean @default(false)

    post? Post[]
    notification?
    follow?
    followers?
    blocked?  
    conversation?
}


model Post {
    id String @id @default(cuid())
    title String
    content? String
    images String[]
    createdAt DateTime @default(now())
    deletedAt? DateTime 
    Category Category
    ModeationStatus ModeationStatus



    likes? PostLike[]
    userId String
    byUser UserProfile @relation("byUser", fields: [userId], references: [id])
}


model PostLike {
    id String @id @default(cuid())

    post_id String
    post Post @relation("post", fields: [post_id], references: [id])

    user_id String
    user UserProfile @relation("user", fields: [user_id], references: [id])

    createdAt DateTime @default(now())

    like Post @relation("like", fields: [post_id], references: [id])

}



